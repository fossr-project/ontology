@prefix : <https://w3id.org/fossr/onto/publications/> .
@prefix ac: <https://w3id.org/fossr/onto/academic-career/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prism: <http://prismstandard.org/namespaces/basic/2.0/> .
@base <https://w3id.org/fossr/onto/publications/> .

<https://w3id.org/fossr/onto/publications> rdf:type owl:Ontology .

#################################################################
#    Object Properties
#################################################################

###  http://www.w3.org/2004/02/skos/core#inScheme
skos:inScheme rdf:type owl:ObjectProperty ;
              owl:equivalentProperty :inScheme .


###  https://w3id.org/fossr/onto/academic-career/isWrittenBy
ac:isWrittenBy rdf:type owl:ObjectProperty ;
               owl:inverseOf ac:wrote ;
               rdfs:domain :Publication ;
               rdfs:range ac:Scholar .


###  https://w3id.org/fossr/onto/academic-career/wrote
ac:wrote rdf:type owl:ObjectProperty ;
         rdfs:domain ac:Scholar ;
         rdfs:range :Publication .


###  https://w3id.org/fossr/onto/publications/contains
:contains rdf:type owl:ObjectProperty ;
          rdfs:domain :Container ;
          rdfs:range :ListItem .


###  https://w3id.org/fossr/onto/publications/containsReferenceTo
:containsReferenceTo rdf:type owl:ObjectProperty ;
                     rdfs:domain :Publication ;
                     rdfs:range :Publication .


###  https://w3id.org/fossr/onto/publications/contributedTo
:contributedTo rdf:type owl:ObjectProperty ;
               owl:inverseOf :hasContributingOrganization ;
               rdfs:domain :OrganizationProfile ;
               rdfs:range :Publication .


###  https://w3id.org/fossr/onto/publications/element
:element rdf:type owl:ObjectProperty .


###  https://w3id.org/fossr/onto/publications/extractedFrom
:extractedFrom rdf:type owl:ObjectProperty ;
               rdfs:domain :InformationObject ;
               rdfs:range :Datasource .


###  https://w3id.org/fossr/onto/publications/first
:first rdf:type owl:ObjectProperty ;
       rdfs:subPropertyOf :contains .


###  https://w3id.org/fossr/onto/publications/hasAffiliation
:hasAffiliation rdf:type owl:ObjectProperty ;
                rdfs:domain :AuthorProfile ;
                rdfs:range :OrganizationProfile .


###  https://w3id.org/fossr/onto/publications/hasAffiliationInPublication
:hasAffiliationInPublication rdf:type owl:ObjectProperty ;
                             rdfs:domain :AuthorItem ;
                             rdfs:range :OrganizationProfile .


###  https://w3id.org/fossr/onto/publications/hasAlias
:hasAlias rdf:type owl:ObjectProperty ,
                   owl:SymmetricProperty ,
                   owl:TransitiveProperty ,
                   owl:ReflexiveProperty ;
          rdfs:domain :Entity ;
          rdfs:range :Entity .


###  https://w3id.org/fossr/onto/publications/hasAuthorList
:hasAuthorList rdf:type owl:ObjectProperty ;
               rdfs:domain :Publication ;
               rdfs:range :AuthorList .


###  https://w3id.org/fossr/onto/publications/hasAuthorProfile
:hasAuthorProfile rdf:type owl:ObjectProperty ;
                  owl:inverseOf :isAuthorProfileOf ;
                  rdfs:domain ac:Scholar ;
                  rdfs:range :AuthorProfile .


###  https://w3id.org/fossr/onto/publications/hasContributingOrganization
:hasContributingOrganization rdf:type owl:ObjectProperty ;
                             rdfs:subPropertyOf owl:topObjectProperty ;
                             rdfs:domain :Publication ;
                             rdfs:range :OrganizationProfile .


###  https://w3id.org/fossr/onto/publications/hasIdentifier
:hasIdentifier rdf:type owl:ObjectProperty ;
               rdfs:domain :Entity ;
               rdfs:range :Identifier .


###  https://w3id.org/fossr/onto/publications/hasItemContent
:hasItemContent rdf:type owl:ObjectProperty ;
                rdfs:domain :ListItem ;
                rdfs:range :Entity .


###  https://w3id.org/fossr/onto/publications/hasName
:hasName rdf:type owl:ObjectProperty ;
         rdfs:domain :Entity ;
         rdfs:range :Name .


###  https://w3id.org/fossr/onto/publications/hasOrganizationType
:hasOrganizationType rdf:type owl:ObjectProperty ;
                     owl:inverseOf :isOrganizationTypeOf ;
                     rdfs:domain :OrganizationProfile ;
                     rdfs:range :OrganizationType .


###  https://w3id.org/fossr/onto/publications/hasParentOrganization
:hasParentOrganization rdf:type owl:ObjectProperty ,
                                owl:TransitiveProperty ;
                       rdfs:domain :OrganizationProfile ;
                       rdfs:range :OrganizationProfile .


###  https://w3id.org/fossr/onto/publications/hasPreferredName
:hasPreferredName rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf :hasName .


###  https://w3id.org/fossr/onto/publications/hasPublicationSourceType
:hasPublicationSourceType rdf:type owl:ObjectProperty ;
                          rdfs:domain :PublicationSource ;
                          rdfs:range :PublicationSourceType .


###  https://w3id.org/fossr/onto/publications/hasPublicationType
:hasPublicationType rdf:type owl:ObjectProperty ;
                    rdfs:domain :Publication ;
                    rdfs:range :PublicationType .


###  https://w3id.org/fossr/onto/publications/hasReferenceList
:hasReferenceList rdf:type owl:ObjectProperty ;
                  rdfs:domain :Publication ;
                  rdfs:range :ReferenceList .


###  https://w3id.org/fossr/onto/publications/inDatasource
:inDatasource rdf:type owl:ObjectProperty .


###  https://w3id.org/fossr/onto/publications/inScheme
:inScheme rdf:type owl:ObjectProperty ;
          rdfs:domain :Concept ;
          rdfs:range :ConceptScheme .


###  https://w3id.org/fossr/onto/publications/isAuthorProfileOf
:isAuthorProfileOf rdf:type owl:ObjectProperty ;
                   rdfs:domain :AuthorProfile ;
                   rdfs:range ac:Scholar .


###  https://w3id.org/fossr/onto/publications/isOrganizationTypeOf
:isOrganizationTypeOf rdf:type owl:ObjectProperty ;
                      rdfs:domain :OrganizationType ;
                      rdfs:range :OrganizationProfile .


###  https://w3id.org/fossr/onto/publications/isPartOf
:isPartOf rdf:type owl:ObjectProperty .


###  https://w3id.org/fossr/onto/publications/last
:last rdf:type owl:ObjectProperty ;
      rdfs:subPropertyOf :contains .


###  https://w3id.org/fossr/onto/publications/next
:next rdf:type owl:ObjectProperty ;
      owl:inverseOf :prev ;
      rdfs:domain :ListItem ;
      rdfs:range :ListItem .


###  https://w3id.org/fossr/onto/publications/prev
:prev rdf:type owl:ObjectProperty ;
      rdfs:domain :ListItem ;
      rdfs:range :ListItem .


###  https://w3id.org/fossr/onto/publications/providedBy
:providedBy rdf:type owl:ObjectProperty ;
            rdfs:domain :ConceptScheme ;
            rdfs:range :Issuer .


#################################################################
#    Classes
#################################################################

###  http://www.w3.org/2004/02/skos/core#Concept
skos:Concept rdf:type owl:Class ;
             owl:equivalentClass :Concept ;
             rdfs:subClassOf :Entity .


###  http://www.w3.org/2004/02/skos/core#ConceptScheme
skos:ConceptScheme rdf:type owl:Class ;
                   owl:equivalentClass :ConceptScheme ;
                   rdfs:subClassOf :Entity .


###  https://w3id.org/fossr/onto/academic-career/Scholar
ac:Scholar rdf:type owl:Class ;
           rdfs:subClassOf :Entity ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :hasAuthorProfile ;
                             owl:someValuesFrom :AuthorProfile
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty ac:wrote ;
                             owl:allValuesFrom :Publication
                           ] .


###  https://w3id.org/fossr/onto/publications/AuthorItem
:AuthorItem rdf:type owl:Class ;
            rdfs:subClassOf :ListItem ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :hasAffiliationInPublication ;
                              owl:someValuesFrom :OrganizationProfile
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :hasItemContent ;
                              owl:allValuesFrom :AuthorProfile
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :next ;
                              owl:allValuesFrom :AuthorItem
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :prev ;
                              owl:allValuesFrom :AuthorItem
                            ] .


###  https://w3id.org/fossr/onto/publications/AuthorList
:AuthorList rdf:type owl:Class ;
            rdfs:subClassOf :List ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :contains ;
                              owl:allValuesFrom :AuthorItem
                            ] .


###  https://w3id.org/fossr/onto/publications/AuthorProfile
:AuthorProfile rdf:type owl:Class ;
               rdfs:subClassOf :InformationObject ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasAffiliation ;
                                 owl:someValuesFrom :OrganizationProfile
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :isAuthorProfileOf ;
                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                 owl:onClass ac:Scholar
                               ] .


###  https://w3id.org/fossr/onto/publications/Concept
:Concept rdf:type owl:Class ;
         rdfs:subClassOf :Entity ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :inScheme ;
                           owl:someValuesFrom :ConceptScheme
                         ] .


###  https://w3id.org/fossr/onto/publications/ConceptScheme
:ConceptScheme rdf:type owl:Class ;
               rdfs:subClassOf :Entity ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :providedBy ;
                                 owl:someValuesFrom :Issuer
                               ] .


###  https://w3id.org/fossr/onto/publications/Container
:Container rdf:type owl:Class ;
           rdfs:subClassOf :Entity .


###  https://w3id.org/fossr/onto/publications/Datasource
:Datasource rdf:type owl:Class ;
            rdfs:subClassOf :Entity .


###  https://w3id.org/fossr/onto/publications/Entity
:Entity rdf:type owl:Class ;
        rdfs:subClassOf [ rdf:type owl:Restriction ;
                          owl:onProperty :hasName ;
                          owl:someValuesFrom :Name
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :hasPreferredName ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onClass :Name
                        ] .


###  https://w3id.org/fossr/onto/publications/Identifier
:Identifier rdf:type owl:Class ;
            rdfs:subClassOf :Concept .


###  https://w3id.org/fossr/onto/publications/InformationObject
:InformationObject rdf:type owl:Class ;
                   rdfs:subClassOf :Entity ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :extractedFrom ;
                                     owl:someValuesFrom :Datasource
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :hasAlias ;
                                     owl:allValuesFrom :InformationObject
                                   ] .


###  https://w3id.org/fossr/onto/publications/Issuer
:Issuer rdf:type owl:Class ;
        rdfs:subClassOf :Entity .


###  https://w3id.org/fossr/onto/publications/List
:List rdf:type owl:Class ;
      rdfs:subClassOf :Container ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :contains ;
                        owl:someValuesFrom :ListItem
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :first ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onClass :ListItem
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :last ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onClass :ListItem
                      ] .


###  https://w3id.org/fossr/onto/publications/ListItem
:ListItem rdf:type owl:Class ;
          rdfs:subClassOf :Entity ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :hasItemContent ;
                            owl:someValuesFrom :Entity
                          ] .


###  https://w3id.org/fossr/onto/publications/Name
:Name rdf:type owl:Class ;
      rdfs:subClassOf :Entity ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :hasIdentifier ;
                        owl:someValuesFrom :Identifier
                      ] .


###  https://w3id.org/fossr/onto/publications/OrganizationProfile
:OrganizationProfile rdf:type owl:Class ;
                     rdfs:subClassOf :InformationObject ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty :hasOrganizationType ;
                                       owl:someValuesFrom :OrganizationType
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty :hasParentOrganization ;
                                       owl:allValuesFrom :OrganizationProfile
                                     ] .


###  https://w3id.org/fossr/onto/publications/OrganizationType
:OrganizationType rdf:type owl:Class ;
                  rdfs:subClassOf :Concept .


###  https://w3id.org/fossr/onto/publications/Publication
:Publication rdf:type owl:Class ;
             rdfs:subClassOf :InformationObject ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty ac:isWrittenBy ;
                               owl:someValuesFrom ac:Scholar
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :hasIdentifier ;
                               owl:someValuesFrom :Identifier
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :hasPublicationType ;
                               owl:someValuesFrom :PublicationType
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :hasReferenceList ;
                               owl:someValuesFrom :ReferenceList
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :containsReferenceTo ;
                               owl:allValuesFrom :Publication
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :hasContributingOrganization ;
                               owl:allValuesFrom :OrganizationProfile
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :hasAuthorList ;
                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                               owl:onClass :AuthorList
                             ] .


###  https://w3id.org/fossr/onto/publications/PublicationSource
:PublicationSource rdf:type owl:Class ;
                   rdfs:subClassOf :InformationObject ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :hasPublicationSourceType ;
                                     owl:someValuesFrom :PublicationSourceType
                                   ] .


###  https://w3id.org/fossr/onto/publications/PublicationSourceType
:PublicationSourceType rdf:type owl:Class ;
                       rdfs:subClassOf :Entity .


###  https://w3id.org/fossr/onto/publications/PublicationType
:PublicationType rdf:type owl:Class ;
                 rdfs:subClassOf :Concept .


###  https://w3id.org/fossr/onto/publications/ReferenceItem
:ReferenceItem rdf:type owl:Class ;
               rdfs:subClassOf :ListItem ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasItemContent ;
                                 owl:allValuesFrom :Publication
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :next ;
                                 owl:allValuesFrom :ReferenceItem
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :prev ;
                                 owl:allValuesFrom :ReferenceItem
                               ] .


###  https://w3id.org/fossr/onto/publications/ReferenceList
:ReferenceList rdf:type owl:Class ;
               rdfs:subClassOf :List ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :contains ;
                                 owl:allValuesFrom :ReferenceItem
                               ] .


